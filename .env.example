# Supabase project URL (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public key (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — SERVER ONLY.
# Never expose to the browser and never commit a real value to git.
SUPABASE_SERVICE_ROLE_KEY=

# Base URL used to build absolute intake links (e.g. http://localhost:3000
# in dev, or your production domain). Falls back to the request origin.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
